#include <stdio.h>

#define MAX 10

// Global variables
int adj[MAX][MAX];
int visited[MAX];
int queue[MAX];
int front = 0, rear = -1;
int count = 0;
int n;

void enqueue(int v) {
    queue[++rear] = v;
}

int dequeue() {
    return queue[front++];
}

int isEmpty() {
    return front > rear;
}

void bfs(int v) {
    int u, w;
    
    // mark v with count and initialize a queue with v
    count++;
    visited[v] = count;
    enqueue(v);
    
    printf("Visited vertex %d, assigned mark: %d\n", v, visited[v]);

    while (!isEmpty()) {
        u = dequeue(); // get the front vertex
        
        // for each vertex w adjacent to the front vertex u
        for (w = 0; w < n; w++) {
            if (adj[u][w] == 1 && visited[w] == 0) {
                count++;
                visited[w] = count; // mark w with count
                printf("Visited vertex %d, assigned mark: %d\n", w, visited[w]);
                enqueue(w); // add w to the queue
            }
        }
    }
}

int main() {
    int i, j;
    int components = 0;

    printf("Enter the number of vertices: ");
    scanf("%d", &n);

    printf("Enter the adjacency matrix (0/1):\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    // Initialize: mark each vertex with 0 (unvisited)
    for (i = 0; i < n; i++) {
        visited[i] = 0;
    }

    printf("\nBFS Traversal Order:\n");

    // Main loop for handling disconnected components
    for (i = 0; i < n; i++) {
        if (visited[i] == 0) {
            components++;
            bfs(i);
        }
    }

    if (components == 1 && count == n) {
        printf("\nThe graph is Connected.\n");
    } else {
        printf("\nThe graph is Not Connected (%d components found).\n", components);
    }

    return 0;
}
