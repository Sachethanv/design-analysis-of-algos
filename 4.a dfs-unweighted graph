#include <stdio.h>
#include <stdbool.h>

#define MAX 10

int adj[MAX][MAX];
int visited[MAX];
int n; // Number of vertices

void DFS(int v) {
    visited[v] = 1; // Mark current node as visited
    for (int i = 0; i < n; i++) {
        // If there is an edge and the vertex isn't visited
        if (adj[v][i] == 1 && !visited[i]) {
            DFS(i);
        }
    }
}

int main() {
    int i, j;

    printf("Enter the number of vertices: ");
    scanf("%d", &n);

    printf("Enter the adjacency matrix (0 or 1):\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    // Initialize visited array to 0
    for (i = 0; i < n; i++) {
        visited[i] = 0;
    }

    // Start DFS from the first vertex (0)
    DFS(0);

    // Check if all vertices were reached
    bool connected = true;
    for (i = 0; i < n; i++) {
        if (visited[i] == 0) {
            connected = false;
            break;
        }
    }

    if (connected) {
        printf("\nThe graph is connected.\n");
    } else {
        printf("\nThe graph is not connected.\n");
    }

    return 0;
}
